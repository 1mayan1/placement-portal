# ─────────────────────────────────────────────────────────
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# Never commit .env.local to GitHub — it contains secrets!
# ─────────────────────────────────────────────────────────

# 1. MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → your cluster → Connect → Drivers
# Format:   mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/mca_placement?retryWrites=true&w=majority

# 2. NextAuth secret — used to encrypt session tokens
# Generate a random string: run this in terminal → openssl rand -base64 32
NEXTAUTH_SECRET=replace_this_with_a_random_string_at_least_32_chars

# 3. NextAuth URL — the base URL of your app
# In development this is always http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# 4. Anthropic (Claude) API key — for all AI features
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 5. Resend API key — for sending emails
# Get from: https://resend.com → API Keys (free tier: 3000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 6. Email sender address (must be verified in Resend)
# On free tier use: onboarding@resend.dev (works without domain verification)
RESEND_FROM_EMAIL=onboarding@resend.dev
